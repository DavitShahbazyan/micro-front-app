{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"],
      "cache": true
    },
    "build:shared": {
      "dependsOn": [],
      "outputs": ["dist/**"],
      "cache": true
    },
    "build:webpack": {
      "dependsOn": [],
      "outputs": ["dist/**"],
      "cache": true
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "serve": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev": {
      "cache": false
    }
  }
}

